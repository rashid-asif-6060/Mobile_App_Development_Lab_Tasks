<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="@color/white"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="10dp"
        android:padding="12dp"
        android:text="Photo Gallery"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="22sp"
        android:gravity="center"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        
        <LinearLayout
            android:id="@+id/containerTab"
            android:orientation="horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp">

            <Button
                android:id="@+id/allTab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All"
                android:textColor="@color/white"
                android:backgroundTint="#0D47A1"/>

            <Button
                android:id="@+id/natureTab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nature"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:backgroundTint="#0D47A1"/>

            <Button
                android:id="@+id/cityTab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="City"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:backgroundTint="#0D47A1"/>

            <Button
                android:id="@+id/animelsTab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Animals"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:backgroundTint="#0D47A1"/>

            <Button
                android:id="@+id/foodTab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Food"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:backgroundTint="#0D47A1"/>

            <Button
                android:id="@+id/travelTab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Travel"
                android:textColor="@color/white"
                android:layout_marginLeft="5dp"
                android:backgroundTint="#0D47A1"/>

        </LinearLayout>
        
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/selectionToolBar"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="10dp"
        android:background="#EEEEEE"
        android:visibility="gone">
        
        <TextView
            android:id="@+id/selectedCount"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="0 selected"
            android:textSize="15sp"
            android:textColor="@color/black"/>

        <Button
            android:id="@+id/deleteBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"/>

        <Button
            android:id="@+id/shareBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Share"
            android:layout_marginLeft="3dp"
            android:textColor="@color/white"
            android:backgroundTint="@color/black"/>

    </LinearLayout>
    
    <GridView
        android:id="@+id/gridView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="2"
        android:verticalSpacing="8dp"
        android:horizontalSpacing="8dp"
        android:padding="8dp"
        android:focusable="false"
        android:clickable="false"/>

</LinearLayout>