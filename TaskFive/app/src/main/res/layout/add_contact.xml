<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:padding="16dp"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/white">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:text="Create Contact"
        android:textColor="@color/black"
        android:textSize="22sp"
        android:textAlignment="center"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>

    <RelativeLayout
        android:id="@+id/avaterAdd"
        android:layout_below="@+id/title"
        android:layout_centerHorizontal="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp">

        <ImageView
            android:id="@+id/avater"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:src="@drawable/undraw_developer_avatar"
            android:layout_centerInParent="true"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="18sp"/>

        <ImageView
            android:id="@+id/add"
            android:layout_width="70dp"
            android:layout_height="50dp"
            android:layout_toEndOf="@+id/avater"
            android:layout_alignBottom="@+id/avater"
            android:src="@android:drawable/ic_menu_add"/>

    </RelativeLayout>

    <TextView
        android:id="@+id/nameLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/avaterAdd"
        android:layout_marginTop="40dp"
        android:text="Name: "
        android:textSize="20sp"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:padding="5dp"/>

    <EditText
        android:id="@+id/nameInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/nameLabel"
        android:background="@drawable/rounded_edittext"
        android:padding="12dp"
        android:hint="Enter name"
        android:textColorHint="@color/black"
        android:textColor="@color/black"/>

    <TextView
        android:id="@+id/phoneLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/nameInput"
        android:layout_marginTop="20dp"
        android:text="Phone: "
        android:textColor="@color/black"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="5dp"/>

    <EditText
        android:id="@+id/phoneInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/phoneLabel"
        android:background="@drawable/rounded_edittext"
        android:padding="12dp"
        android:hint="Enter phone number"
        android:textColorHint="@color/black"
        android:textColor="@color/black"/>
    
    <Button
        android:id="@+id/saveBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/footer"
        android:layout_centerHorizontal="true"
        android:text="Save"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="@color/black"/>

    <TextView
        android:id="@+id/footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="30dp"
        android:text="Saving to device and Google"
        android:textColor="@color/black"
        android:textAlignment="center"
        android:textSize="16sp"
        android:textStyle="bold"/>

</RelativeLayout>